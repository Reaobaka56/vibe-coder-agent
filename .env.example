# Vibe-Coder-Agent Environment Variables

TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_NUMBER=

QWEN_API_URL=
QWEN_API_KEY=
QWEN_MODEL=qwen2.5-coder:14b

GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

VERCEL_TOKEN=
VERCEL_TEAM_ID=

REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vibe_coder
MAX_PROJECTS_PER_NUMBER=2
MAX_EDITS_PER_PROJECT=20

# Rate limiting & cost control
RATE_LIMIT_REQUESTS_PER_MINUTE=5
RATE_LIMIT_WINDOW_SECONDS=60
MAX_GENERATIONS_PER_DAY=10
MAX_GENERATION_ATTEMPTS_BEFORE_COOLDOWN=3

# Auth
REQUIRE_ACCESS_TOKEN=true
ADMIN_WA_NUMBERS=

BASE_URL=https://your-ngrok.ngrok-free.app

